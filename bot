import time
import sys
import subprocess 

def menu_principal():
    print("¡BIENVENIDO AL BOT! 😊")
    print(" "*30)
    print("¡Qué se te ofrece hacer el dia de hoy estimado compañero?")
    print("1. Escuchar musiquita🎶")
    print("2. Pintar y hacer una obra maestra🎨")
    print("3. Saber q tanto sabes de cultura general😎")
    print("4. Jugar un minijuego🎮")
    print("5. O irte pal carriso y no hablar conmigo")
    print("="*30)

def seccion_musica():
    print("\n🎵 --- RINCÓN MUSICAL ---")
    print("Iniciando el reproductor de música automático...")
    time.sleep(1)
    
    try:
        subprocess.run([sys.executable, "mus.py"], check=True)
        print("\n🎵 Regresando al menú del bot...")
    except FileNotFoundError:
        print("\n❌ Error: No se encontró el archivo 'mus.py'. Asegúrate de que esté en la misma carpeta.")
    except subprocess.CalledProcessError:
        print("\n❌ Hubo un problema al ejecutar 'mus.py'.")
    
    time.sleep(1.5)

